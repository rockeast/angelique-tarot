# ========================================
# Angel Tarot — 環境変数テンプレート
# ========================================
# このファイルをコピーして .env にリネームし、実際の値を入力してください
# cp .env.example .env

# Groq API キー (https://console.groq.com でAPIキーを発行)
GROQ_API_KEY=your_groq_api_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Stripe 決済キー (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_MONTHLY=price_xxxxx
STRIPE_PRICE_YEARLY=price_xxxxx

# カンマ区切り。例: https://example.com,https://www.example.com
# 未指定の場合、ブラウザからのクロスオリジンAPIアクセスは許可しません。
ALLOWED_ORIGINS=

# サーバーポート
PORT=3000
NODE_ENV=production
